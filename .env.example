# Anthropic Claude - https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Model (default: claude-sonnet-5)
LLM_MODEL=claude-sonnet-5

LOG_TO_FILE=0
PORT=7860

# Qdrant (decision history RAG). Leave unset to use an in-memory instance.
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=decision_history

# Neo4j Aura (sector GraphRAG). Leave unset to use the local fixture instead.
NEO4J_URI=
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# SecurityLayer (prompt-injection guard). Toggleable live via /security.
SECURITY_ENABLED=1
